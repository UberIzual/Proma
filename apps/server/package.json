{
  "name": "@proma/server",
  "version": "0.1.0",
  "description": "Proma Web Backend Service - Bun + Hono",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.38",
    "@proma/core": "workspace:*",
    "@proma/shared": "workspace:*",
    "hono": "^4.6.0",
    "undici": "^7.21.0",
    "pdf-parse": "1.1.1",
    "word-extractor": "1.0.4",
    "officeparser": "4.2.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
